{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "JSON-stat 2.0 Curated Index Schema",
  "$id": "https://json-stat.org/curated/2.0/index.json",
  "description": "Curated de-duplicated index schema (general oneOf of all three classes). The vendored schemas/vendored/index.json re-inlines the full per-class property sets three times inside its oneOf; this version $refs core.json#/$defs/{datasetProperties,dimensionProperties,collectionProperties} once each, which is the single largest de-duplication win. Semantically equivalent (enforced by the curated-equiv-vendored parity test).",
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "class": {
          "type": "string",
          "enum": [
            "dataset"
          ]
        },
        "version": {
          "type": "string",
          "enum": [
            "2.0"
          ]
        },
        "href": {
          "type": "string",
          "format": "uri"
        },
        "label": {
          "type": "string"
        },
        "note": {
          "$ref": "#/oneOf/0/properties/id"
        },
        "link": {
          "type": "object",
          "patternProperties": {
            "^(about|alternate|appendix|archives|author|blocked-by|bookmark|canonical|chapter|collection|contents|copyright|create-form|current|derivedfrom|describedby|describes|disclosure|dns-prefetch|duplicate|edit|edit-form|edit-media|enclosure|first|glossary|help|hosts|hub|icon|index|item|last|latest-version|license|lrdd|memento|monitor|monitor-group|next|next-archive|nofollow|noreferrer|original|payment|pingback|preconnect|predecessor-version|prefetch|preload|prerender|prev|preview|previous|prev-archive|privacy-policy|profile|related|replies|search|section|self|service|start|stylesheet|subsection|successor-version|tag|terms-of-service|timegate|timemap|type|up|version-history|via|webmention|working-copy|working-copy-of)$": {
              "type": "array",
              "items": {
                "$ref": "#/oneOf/2/properties/link/properties/item/items"
              }
            }
          },
          "additionalProperties": false
        },
        "updated": {
          "oneOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "pattern": "^((19|20)\\d\\d)-(0?[1-9]|1[012])-(0?[1-9]|[12][0-9]|3[01])$"
            }
          ]
        },
        "source": {
          "type": "string"
        },
        "error": {
          "type": "array"
        },
        "extension": {
          "type": "object"
        },
        "id": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "size": {
          "type": "array",
          "items": {
            "type": "integer"
          }
        },
        "role": {
          "type": "object",
          "properties": {
            "time": {
              "$ref": "#/oneOf/0/properties/id"
            },
            "geo": {
              "$ref": "#/oneOf/0/properties/id"
            },
            "metric": {
              "$ref": "#/oneOf/0/properties/id"
            }
          },
          "additionalProperties": false
        },
        "dimension": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "href": {
                "$ref": "#/oneOf/0/properties/href"
              },
              "label": {
                "$ref": "#/oneOf/0/properties/label"
              },
              "note": {
                "$ref": "#/oneOf/0/properties/id"
              },
              "link": {
                "$ref": "#/oneOf/0/properties/link"
              },
              "extension": {
                "$ref": "#/oneOf/0/properties/extension"
              },
              "category": {
                "$ref": "#/oneOf/1/properties/category"
              }
            },
            "additionalProperties": false,
            "required": [
              "category"
            ]
          }
        },
        "value": {
          "oneOf": [
            {
              "type": "array",
              "items": {
                "anyOf": [
                  {
                    "type": "number"
                  },
                  {
                    "type": "null"
                  },
                  {
                    "type": "string"
                  }
                ]
              }
            },
            {
              "type": "object",
              "additionalProperties": {
                "anyOf": [
                  {
                    "type": "number"
                  },
                  {
                    "type": "null"
                  },
                  {
                    "type": "string"
                  }
                ]
              }
            }
          ]
        },
        "status": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "version",
        "class",
        "value",
        "id",
        "size",
        "dimension"
      ]
    },
    {
      "type": "object",
      "properties": {
        "class": {
          "type": "string",
          "enum": [
            "dimension"
          ]
        },
        "version": {
          "$ref": "#/oneOf/0/properties/version"
        },
        "href": {
          "$ref": "#/oneOf/0/properties/href"
        },
        "label": {
          "$ref": "#/oneOf/0/properties/label"
        },
        "note": {
          "$ref": "#/oneOf/0/properties/id"
        },
        "link": {
          "$ref": "#/oneOf/0/properties/link"
        },
        "updated": {
          "$ref": "#/oneOf/0/properties/updated"
        },
        "source": {
          "$ref": "#/oneOf/0/properties/source"
        },
        "error": {
          "$ref": "#/oneOf/0/properties/error"
        },
        "extension": {
          "$ref": "#/oneOf/0/properties/extension"
        },
        "category": {
          "type": "object",
          "properties": {
            "index": {
              "oneOf": [
                {
                  "$ref": "#/oneOf/0/properties/id"
                },
                {
                  "type": "object",
                  "additionalProperties": {
                    "type": "number"
                  }
                }
              ]
            },
            "label": {
              "type": "object",
              "minProperties": 1,
              "additionalProperties": {
                "type": "string"
              }
            },
            "note": {
              "type": "object",
              "additionalProperties": {
                "$ref": "#/oneOf/0/properties/id"
              }
            },
            "unit": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "label": {
                    "$ref": "#/oneOf/0/properties/label"
                  },
                  "decimals": {
                    "type": "integer"
                  },
                  "position": {
                    "type": "string",
                    "enum": [
                      "start",
                      "end"
                    ]
                  }
                }
              }
            },
            "coordinates": {
              "type": "object",
              "additionalProperties": {
                "type": "array",
                "prefixItems": [
                  {
                    "type": "number"
                  },
                  {
                    "type": "number"
                  }
                ],
                "items": false
              }
            },
            "child": {
              "type": "object",
              "additionalProperties": {
                "$ref": "#/oneOf/0/properties/id"
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false,
      "required": [
        "version",
        "class",
        "category"
      ]
    },
    {
      "type": "object",
      "properties": {
        "class": {
          "type": "string",
          "enum": [
            "collection"
          ]
        },
        "version": {
          "$ref": "#/oneOf/0/properties/version"
        },
        "href": {
          "$ref": "#/oneOf/0/properties/href"
        },
        "label": {
          "$ref": "#/oneOf/0/properties/label"
        },
        "note": {
          "$ref": "#/oneOf/0/properties/id"
        },
        "link": {
          "type": "object",
          "properties": {
            "item": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string"
                  },
                  "class": {
                    "type": "string",
                    "enum": [
                      "dataset",
                      "collection",
                      "dimension"
                    ]
                  },
                  "href": {
                    "$ref": "#/oneOf/0/properties/href"
                  },
                  "label": {
                    "$ref": "#/oneOf/0/properties/label"
                  },
                  "note": {
                    "$ref": "#/oneOf/0/properties/id"
                  },
                  "link": {
                    "$ref": "#/oneOf/0/properties/link"
                  },
                  "updated": {
                    "$ref": "#/oneOf/0/properties/updated"
                  },
                  "source": {
                    "$ref": "#/oneOf/0/properties/source"
                  },
                  "extension": {
                    "$ref": "#/oneOf/0/properties/extension"
                  },
                  "category": {
                    "$ref": "#/oneOf/1/properties/category"
                  },
                  "id": {
                    "$ref": "#/oneOf/0/properties/id"
                  },
                  "size": {
                    "$ref": "#/oneOf/0/properties/size"
                  },
                  "role": {
                    "$ref": "#/oneOf/0/properties/role"
                  },
                  "dimension": {
                    "$ref": "#/oneOf/0/properties/dimension"
                  },
                  "value": {
                    "$ref": "#/oneOf/0/properties/value"
                  },
                  "status": {
                    "$ref": "#/oneOf/0/properties/status"
                  }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        },
        "updated": {
          "$ref": "#/oneOf/0/properties/updated"
        },
        "source": {
          "$ref": "#/oneOf/0/properties/source"
        },
        "error": {
          "$ref": "#/oneOf/0/properties/error"
        },
        "extension": {
          "$ref": "#/oneOf/0/properties/extension"
        }
      },
      "additionalProperties": false,
      "required": [
        "version",
        "class",
        "link"
      ]
    }
  ]
}
