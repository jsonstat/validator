{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "JSON-stat 2.0 Curated Dimension Schema",
  "$id": "https://json-stat.org/curated/2.0/dimension.json",
  "description": "Curated de-duplicated dimension schema. All shared definitions live in core.json and are inlined by tools/bundle-schemas.mjs at build time. Semantically equivalent to the vendored schemas/vendored/dimension.json (enforced by the curated-equiv-vendored parity test).",
  "type": "object",
  "properties": {
    "class": {
      "type": "string",
      "enum": [
        "dimension"
      ]
    },
    "version": {
      "type": "string",
      "enum": [
        "2.0"
      ]
    },
    "href": {
      "type": "string",
      "format": "uri"
    },
    "label": {
      "type": "string"
    },
    "note": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "link": {
      "type": "object",
      "patternProperties": {
        "^(about|alternate|appendix|archives|author|blocked-by|bookmark|canonical|chapter|collection|contents|copyright|create-form|current|derivedfrom|describedby|describes|disclosure|dns-prefetch|duplicate|edit|edit-form|edit-media|enclosure|first|glossary|help|hosts|hub|icon|index|item|last|latest-version|license|lrdd|memento|monitor|monitor-group|next|next-archive|nofollow|noreferrer|original|payment|pingback|preconnect|predecessor-version|prefetch|preload|prerender|prev|preview|previous|prev-archive|privacy-policy|profile|related|replies|search|section|self|service|start|stylesheet|subsection|successor-version|tag|terms-of-service|timegate|timemap|type|up|version-history|via|webmention|working-copy|working-copy-of)$": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string"
              },
              "class": {
                "type": "string",
                "enum": [
                  "dataset",
                  "collection",
                  "dimension"
                ]
              },
              "href": {
                "$ref": "#/properties/href"
              },
              "label": {
                "$ref": "#/properties/label"
              },
              "note": {
                "$ref": "#/properties/note"
              },
              "link": {
                "$ref": "#/properties/link"
              },
              "updated": {
                "$ref": "#/properties/updated"
              },
              "source": {
                "$ref": "#/properties/source"
              },
              "extension": {
                "$ref": "#/properties/extension"
              },
              "category": {
                "$ref": "#/properties/category"
              },
              "id": {
                "$ref": "#/properties/note"
              },
              "size": {
                "type": "array",
                "items": {
                  "type": "integer"
                }
              },
              "role": {
                "type": "object",
                "properties": {
                  "time": {
                    "$ref": "#/properties/note"
                  },
                  "geo": {
                    "$ref": "#/properties/note"
                  },
                  "metric": {
                    "$ref": "#/properties/note"
                  }
                },
                "additionalProperties": false
              },
              "dimension": {
                "type": "object",
                "additionalProperties": {
                  "type": "object",
                  "properties": {
                    "href": {
                      "$ref": "#/properties/href"
                    },
                    "label": {
                      "$ref": "#/properties/label"
                    },
                    "note": {
                      "$ref": "#/properties/note"
                    },
                    "link": {
                      "$ref": "#/properties/link"
                    },
                    "extension": {
                      "$ref": "#/properties/extension"
                    },
                    "category": {
                      "$ref": "#/properties/category"
                    }
                  },
                  "additionalProperties": false,
                  "required": [
                    "category"
                  ]
                }
              },
              "value": {
                "oneOf": [
                  {
                    "type": "array",
                    "items": {
                      "anyOf": [
                        {
                          "type": "number"
                        },
                        {
                          "type": "null"
                        },
                        {
                          "type": "string"
                        }
                      ]
                    }
                  },
                  {
                    "type": "object",
                    "additionalProperties": {
                      "anyOf": [
                        {
                          "type": "number"
                        },
                        {
                          "type": "null"
                        },
                        {
                          "type": "string"
                        }
                      ]
                    }
                  }
                ]
              },
              "status": {
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": [
                        "string",
                        "null"
                      ]
                    }
                  },
                  {
                    "type": "object",
                    "additionalProperties": {
                      "type": "string"
                    }
                  }
                ]
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "updated": {
      "oneOf": [
        {
          "type": "string",
          "format": "date-time"
        },
        {
          "type": "string",
          "pattern": "^((19|20)\\d\\d)-(0?[1-9]|1[012])-(0?[1-9]|[12][0-9]|3[01])$"
        }
      ]
    },
    "source": {
      "type": "string"
    },
    "error": {
      "type": "array"
    },
    "extension": {
      "type": "object"
    },
    "category": {
      "type": "object",
      "properties": {
        "index": {
          "oneOf": [
            {
              "$ref": "#/properties/note"
            },
            {
              "type": "object",
              "additionalProperties": {
                "type": "number"
              }
            }
          ]
        },
        "label": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "string"
          }
        },
        "note": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/properties/note"
          }
        },
        "unit": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "label": {
                "$ref": "#/properties/label"
              },
              "decimals": {
                "type": "integer"
              },
              "position": {
                "type": "string",
                "enum": [
                  "start",
                  "end"
                ]
              }
            }
          }
        },
        "coordinates": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "prefixItems": [
              {
                "type": "number"
              },
              {
                "type": "number"
              }
            ],
            "items": false
          }
        },
        "child": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/properties/note"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "required": [
    "version",
    "class",
    "category"
  ]
}
